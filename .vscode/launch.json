{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🦉 Magpie Agent",
      "type": "debugpy",
      "request": "launch",
      "module": "magpie_agent.run",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": true
    },
    {
      "name": "🦇 Bat Daemon",
      "type": "debugpy",
      "request": "launch",
      "module": "bat_daemon.run",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": true
    },
    {
      "name": "🧪 Bat Backtest",
      "type": "debugpy",
      "request": "launch",
      "module": "bat_daemon.backtest",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--strategy-user-id",
        "test_developer_001",
        "--backtest-id",
        "backtest_001",
        "--start",
        "2024-01-01 00:00:00",
        "--end",
        "2024-02-01 00:00:00"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": true
    }
  ]
}
